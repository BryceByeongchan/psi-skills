{
  "program": "absorption.x",
  "keywords": {
    "number_val_bands_fine": {"type": "INTEGER", "default": null, "info": "Number of valence bands on fine k-grid (WFNq_fi). REQUIRED."},
    "number_val_bands_coarse": {"type": "INTEGER", "default": null, "info": "Number of valence bands on coarse k-grid (WFN_co). REQUIRED."},
    "number_cond_bands_fine": {"type": "INTEGER", "default": null, "info": "Number of conduction bands on fine k-grid (WFN_fi). REQUIRED."},
    "number_cond_bands_coarse": {"type": "INTEGER", "default": null, "info": "Number of conduction bands on coarse k-grid (WFN_co). REQUIRED."},
    "lowest_occupied_band": {"type": "INTEGER", "default": 1, "info": "Lowest occupied band index (vmin) for metallic systems."},
    "highest_occupied_band": {"type": "INTEGER", "default": 0, "info": "Highest occupied band index (vmax) for metallic systems."},
    "energy_resolution": {"type": "REAL", "default": null, "info": "Broadening width for absorption spectrum (eV). REQUIRED."},
    "energy_resolution_sigma": {"type": "REAL", "default": 0.0, "info": "Gaussian component for Voigt broadening (eV)."},
    "energy_resolution_gamma": {"type": "REAL", "default": 0.0, "info": "Lorentzian component for Voigt broadening (eV)."},
    "delta_frequency": {"type": "REAL", "default": 0.01, "info": "Frequency step for spectrum generation (eV)."},
    "cvfit": {"type": "REAL_ARRAY", "default": null, "info": "Scissors operator: evs ev0 evdel ecs ec0 ecdel (6 values, eV)."},
    "evs": {"type": "REAL", "default": 0.0, "info": "Valence scissors shift (eV)."},
    "ev0": {"type": "REAL", "default": 0.0, "info": "Valence reference energy (eV)."},
    "evdel": {"type": "REAL", "default": 0.0, "info": "Valence scissors slope."},
    "ecs": {"type": "REAL", "default": 0.0, "info": "Conduction scissors shift (eV)."},
    "ec0": {"type": "REAL", "default": 0.0, "info": "Conduction reference energy (eV)."},
    "ecdel": {"type": "REAL", "default": 0.0, "info": "Conduction scissors slope."},
    "spline_scissors": {"type": "LOGICAL", "default": false, "info": "Use spline QP corrections from spline_scissors.dat."},
    "eqp_corrections": {"type": "LOGICAL", "default": false, "info": "Use QP corrections from eqp.dat/eqp_q.dat on fine grid."},
    "eqp_co_corrections": {"type": "LOGICAL", "default": false, "info": "Use QP corrections from eqp_co.dat, interpolated to fine grid."},
    "eqp_co_q_corrections": {"type": "LOGICAL", "default": false, "info": "Use Q-dependent corrections from eqp_co_q.dat."},
    "avgpot": {"type": "REAL", "default": 0.0, "info": "Average potential on cell faces (eV)."},
    "fermi_level": {"type": "REAL", "default": 0.0, "info": "Shift Fermi level (eV)."},
    "fermi_level_absolute": {"type": "LOGICAL", "default": false, "info": "Absolute Fermi level."},
    "fermi_level_relative": {"type": "LOGICAL", "default": true, "info": "Relative Fermi level (default)."},
    "read_kpoints": {"type": "LOGICAL", "default": false, "info": "Read k-points from kpoints file."},
    "no_symmetries_fine_grid": {"type": "LOGICAL", "default": true, "info": "Don't use symmetries for WFN_fi."},
    "use_symmetries_fine_grid": {"type": "LOGICAL", "default": false, "info": "Use symmetries for WFN_fi."},
    "no_symmetries_shifted_grid": {"type": "LOGICAL", "default": true, "info": "Don't use symmetries for WFNq_fi."},
    "use_symmetries_shifted_grid": {"type": "LOGICAL", "default": false, "info": "Use symmetries for WFNq_fi."},
    "no_symmetries_coarse_grid": {"type": "LOGICAL", "default": true, "info": "Don't use symmetries for WFN_co."},
    "use_symmetries_coarse_grid": {"type": "LOGICAL", "default": false, "info": "Use symmetries for WFN_co (must match kernel.inp)."},
    "regular_grid": {"type": "INTEGER_ARRAY", "default": null, "info": "Regular grid for k-point averaging (n1 n2 n3)."},
    "patched_sampling": {"type": "LOGICAL", "default": false, "info": "Non-uniform patch sampling."},
    "fullbz_replace": {"type": "LOGICAL", "default": false, "info": "Replace unfolded BZ with full BZ (experimental)."},
    "fullbz_write": {"type": "LOGICAL", "default": false, "info": "Write BZ to files (experimental)."},
    "use_velocity": {"type": "LOGICAL", "default": false, "info": "Use velocity operator for dipole transitions (recommended)."},
    "q_shift": {"type": "REAL_ARRAY", "default": null, "info": "Q shift between WFN_fi and WFNq_fi (3 values)."},
    "use_momentum": {"type": "LOGICAL", "default": false, "info": "Use momentum operator (no WFNq_fi needed)."},
    "polarization": {"type": "REAL_ARRAY", "default": null, "info": "Polarization vector (3 values). REQUIRED with use_momentum."},
    "use_dos": {"type": "LOGICAL", "default": false, "info": "Use JDOS operator. Only with Haydock."},
    "tda_bse": {"type": "LOGICAL", "default": true, "info": "Use Tamm-Dancoff approximation (default)."},
    "full_bse": {"type": "LOGICAL", "default": false, "info": "Solve full BSE without TDA."},
    "full_bse_solver_sseig": {"type": "LOGICAL", "default": null, "info": "Structure-preserving eigenvalue solver (default in MPI)."},
    "full_bse_solver_gvx": {"type": "LOGICAL", "default": null, "info": "General eigenvalue solver (default in serial)."},
    "full_bse_solver_elpa": {"type": "LOGICAL", "default": false, "info": "ELPA solver for full BSE."},
    "extended_kernel": {"type": "LOGICAL", "default": false, "info": "Kernel for all (n1,n2)->(n1',n2'). Auto-set with full_bse."},
    "unrestricted_transformation": {"type": "LOGICAL", "default": false, "info": "Unrestricted WFN transformation. Auto-set with extended_kernel."},
    "zero_unrestricted_contribution": {"type": "LOGICAL", "default": false, "info": "Zero d_vc' and d_cv' coefficients (testing)."},
    "diagonalization": {"type": "LOGICAL", "default": true, "info": "Use full diagonalization (ScaLAPACK/LAPACK/ELPA)."},
    "diagonalization_primme": {"type": "LOGICAL", "default": false, "info": "Use PRIMME iterative diagonalization (TDA only)."},
    "lanczos": {"type": "LOGICAL", "default": false, "info": "Use Lanczos iterative solver."},
    "haydock": {"type": "LOGICAL", "default": false, "info": "Use Haydock iterative solver (Lorentzian only)."},
    "number_iterations": {"type": "INTEGER", "default": 100, "info": "Number of iterations for Haydock/Lanczos."},
    "number_eigenvalues": {"type": "INTEGER", "default": 0, "info": "Number of lowest eigenvalues to compute (0=all)."},
    "primme_tolerance": {"type": "REAL", "default": 1e-6, "info": "Convergence tolerance for PRIMME."},
    "primme_max_basis_size": {"type": "INTEGER", "default": 256, "info": "Max Krylov basis size for PRIMME."},
    "primme_max_block_size": {"type": "INTEGER", "default": 8, "info": "Max simultaneous matvecs for PRIMME."},
    "primme_algo": {"type": "STRING", "default": null, "info": "PRIMME matvec algorithm: CPU_ALGO, OPENACC_ALGO, OMP_TARGET_ALGO."},
    "lorentzian_broadening": {"type": "LOGICAL", "default": false, "info": "Use Lorentzian broadening (only with Haydock)."},
    "gaussian_broadening": {"type": "LOGICAL", "default": true, "info": "Use Gaussian broadening (default for diagonalization)."},
    "voigt_broadening": {"type": "LOGICAL", "default": false, "info": "Use Voigt profile (diagonalization only)."},
    "spin_triplet": {"type": "LOGICAL", "default": false, "info": "Calculate triplet excitons."},
    "spin_singlet": {"type": "LOGICAL", "default": true, "info": "Calculate singlet excitons (default)."},
    "local_fields": {"type": "LOGICAL", "default": false, "info": "Include local-field effects (RPA + exchange only)."},
    "spinor": {"type": "LOGICAL", "default": false, "info": "Use fully-relativistic spinor wavefunctions."},
    "noeh_only": {"type": "LOGICAL", "default": false, "info": "Calculate non-interacting spectrum only (no e-h, RPA only)."},
    "exciton_Q_shift": {"type": "BLOCK_INLINE", "default": null, "info": "Finite Q absorption. Format: Qflag Qx Qy Qz."},
    "zero_q0_element": {"type": "INTEGER", "default": 0, "info": "Zero W(q=0): 0=no, 1=after interpolation, 2=before interpolation."},
    "subsample_line": {"type": "REAL", "default": null, "info": "CSI cutoff in a.u. Requires subsample.inp."},
    "subsample_algo": {"type": "INTEGER", "default": 0, "info": "Vertex selection: 0=reproducible, 1=closest coarse point."},
    "skip_interpolation": {"type": "LOGICAL", "default": false, "info": "Skip kernel interpolation when coarse=fine grid."},
    "kernel_k_interpolation": {"type": "LOGICAL", "default": false, "info": "Enable k-point interpolation for kernel."},
    "kernel_scaling": {"type": "REAL", "default": 1.0, "info": "Arbitrary scaling factor for kernel."},
    "average_w": {"type": "LOGICAL", "default": true, "info": "Average head of W using model inverse dielectric matrix."},
    "cell_average_cutoff": {"type": "REAL", "default": null, "info": "Cutoff for Monte-Carlo Coulomb averaging (Ry)."},
    "degeneracy_check_override": {"type": "LOGICAL", "default": false, "info": "Suppress degeneracy check."},
    "greedy_interpolation": {"type": "LOGICAL", "default": false, "info": "Use greedy interpolation (deprecated)."},
    "delaunay_interpolation": {"type": "LOGICAL", "default": true, "info": "Use Delaunay tessellation interpolation (default)."},
    "kpt_interpolation_linear": {"type": "LOGICAL", "default": false, "info": "Linear interpolation of QP corrections."},
    "kpt_interpolation_exp_transform": {"type": "LOGICAL", "default": true, "info": "Exponential transform for QP corrections (default)."},
    "read_eigenvalues": {"type": "LOGICAL", "default": false, "info": "Read eigenvalues from eigenvalues.dat."},
    "read_dtmat": {"type": "LOGICAL", "default": false, "info": "Read interpolation matrices from dtmat."},
    "read_dtmat_sub": {"type": "LOGICAL", "default": false, "info": "Read subsampled interpolation matrices."},
    "read_vmtxel": {"type": "LOGICAL", "default": false, "info": "Read optical matrix elements from vmtxel."},
    "read_eps2_moments": {"type": "LOGICAL", "default": false, "info": "Read eps2_moments (Haydock only)."},
    "read_epsdiag": {"type": "LOGICAL", "default": false, "info": "Read diagonal epsilon from epsdiag.dat."},
    "write_eigenvectors": {"type": "INTEGER", "default": 0, "info": "Write eigenvectors: 0=no, <0=all, >0=first N."},
    "dump_bse_hamiltonian": {"type": "LOGICAL", "default": false, "info": "Dump BSE Hamiltonian to hbse.h5."},
    "read_bse_hamiltonian": {"type": "LOGICAL", "default": false, "info": "Read BSE Hamiltonian from hbse.h5."},
    "use_wfn_hdf5": {"type": "LOGICAL", "default": false, "info": "Read WFN in HDF5 format."},
    "wfn_hdf5_min_band_block": {"type": "INTEGER", "default": -1, "info": "Min band block size for HDF5 WFN reading."},
    "dont_use_hdf5": {"type": "LOGICAL", "default": false, "info": "Disable HDF5 I/O."},
    "dont_use_hdf5_output": {"type": "LOGICAL", "default": false, "info": "Disable HDF5 output only."},
    "write_vcoul": {"type": "LOGICAL", "default": false, "info": "Write bare Coulomb potential to file."},
    "dont_check_norms": {"type": "LOGICAL", "default": false, "info": "Skip WFN norm checks."},
    "use_elpa": {"type": "LOGICAL", "default": null, "info": "Use ELPA for diagonalization."},
    "dont_use_elpa": {"type": "LOGICAL", "default": false, "info": "Force ScaLAPACK instead of ELPA."},
    "lanczos_gauss_quadrature": {"type": "LOGICAL", "default": true, "info": "Use Gaussian quadrature for Lanczos (~2x speedup)."},
    "no_lanczos_gauss_quadrature": {"type": "LOGICAL", "default": false, "info": "Disable Gaussian quadrature for Lanczos."},
    "zero_coupling_block": {"type": "LOGICAL", "default": false, "info": "Zero coupling block in full BSE (testing only)."},
    "screening_semiconductor": {"type": "LOGICAL", "default": true, "info": "Semiconductor screening (default)."},
    "screening_graphene": {"type": "LOGICAL", "default": false, "info": "Graphene screening."},
    "screening_metal": {"type": "LOGICAL", "default": false, "info": "Metal screening."},
    "spherical_truncation": {"type": "LOGICAL", "default": false, "info": "Spherical Coulomb truncation."},
    "cell_wire_truncation": {"type": "LOGICAL", "default": false, "info": "Wire Coulomb truncation (1D)."},
    "cell_box_truncation": {"type": "LOGICAL", "default": false, "info": "Box Coulomb truncation (0D)."},
    "cell_slab_truncation": {"type": "LOGICAL", "default": false, "info": "Slab Coulomb truncation (2D)."},
    "coulomb_truncation_radius": {"type": "REAL", "default": 0.0, "info": "Spherical truncation radius (Bohr)."},
    "coulomb_truncation_x": {"type": "REAL", "default": 0.0, "info": "Truncation parameter for box/wire/slab."},
    "use_gpu": {"type": "LOGICAL", "default": null, "info": "Enable GPU acceleration."},
    "verbosity": {"type": "INTEGER", "default": 0, "info": "Verbosity level."}
  },
  "blocks": [],
  "aliases": {}
}
