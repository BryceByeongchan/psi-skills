{
  "program": "sigma.x",
  "keywords": {
    "screened_coulomb_cutoff": {"type": "REAL", "default": null, "info": "Cutoff for screened Coulomb interaction W(q) in Ry. Must be <= epsilon_cutoff."},
    "bare_coulomb_cutoff": {"type": "REAL", "default": null, "info": "Cutoff for bare Coulomb interaction v(q+G) in Ry."},
    "cell_average_cutoff": {"type": "REAL", "default": -1, "info": "Cutoff (Ry) for averaging Coulomb in mini-BZ around Gamma."},
    "number_bands": {"type": "INTEGER", "default": null, "info": "Total number of bands (valence+conduction) to sum over."},
    "number_core_excluded": {"type": "INTEGER", "default": 0, "info": "Number of core bands excluded."},
    "band_index_min": {"type": "INTEGER", "default": null, "info": "Minimum band index for diagonal matrix elements."},
    "band_index_max": {"type": "INTEGER", "default": null, "info": "Maximum band index for diagonal matrix elements."},
    "spin_index_min": {"type": "INTEGER", "default": 1, "info": "Minimum spin index."},
    "spin_index_max": {"type": "INTEGER", "default": 1, "info": "Maximum spin index."},
    "number_diag": {"type": "INTEGER", "default": 0, "info": "Number of diagonal matrix elements."},
    "number_offdiag": {"type": "INTEGER", "default": 0, "info": "Number of off-diagonal matrix elements."},
    "sigma_matrix": {"type": "INTEGER_ARRAY", "default": null, "info": "Energy index l and triangle t for off-diagonal. l>0: eigenvalue of band l; l=-1: n_i; l=-2: m_i. t=0: full; t=-1: lower; t=+1: upper."},
    "frequency_dependence": {"type": "INTEGER", "default": 1, "info": "-1=Hartree-Fock, 0=static COHSEX, 1=GPP (HL), 2=full frequency, 3=GN-GPP."},
    "frequency_dependence_method": {"type": "INTEGER", "default": 2, "info": "0=real-axis integration, 2=contour deformation."},
    "for_EXX": {"type": "LOGICAL", "default": false, "info": "Bare exchange only (exact exchange). Skips VXC."},
    "frequency_grid_shift": {"type": "INTEGER", "default": 2, "info": "0=absolute, 1=Fermi-shifted, 2=QP-centered (default)."},
    "init_frequency_eval": {"type": "REAL", "default": 0.0, "info": "Initial frequency (eV) for grid (shift=0 or 1)."},
    "delta_frequency_eval": {"type": "REAL", "default": 0.2, "info": "Frequency spacing (eV)."},
    "number_frequency_eval": {"type": "INTEGER", "default": 1, "info": "Number of frequency points (shift=0 or 1)."},
    "max_frequency_eval": {"type": "REAL", "default": 2.0, "info": "Max frequency (eV) for QP-centered grid (shift=2)."},
    "cd_integration_method": {"type": "INTEGER", "default": 0, "info": "0=piecewise constant, 2=quadratic, 3=cubic Hermite."},
    "finite_difference_form": {"type": "INTEGER", "default": 2, "info": "-3=grid, -2=none, -1=backward, 0=central, 1=forward, 2=default."},
    "finite_difference_spacing": {"type": "REAL", "default": 1.0, "info": "Finite difference spacing (eV)."},
    "gpp_broadening": {"type": "REAL", "default": 0.5, "info": "Broadening for GPP energy denominator (eV)."},
    "gpp_sexcutoff": {"type": "REAL", "default": 4.0, "info": "Cutoff for poles in SX within GPP."},
    "invalid_gpp_mode": {"type": "INTEGER", "default": -1, "info": "-1=default, 0=skip, 1=complex, 2=fixed 2Ry, 3=static COHSEX."},
    "use_epsilon_remainder": {"type": "LOGICAL", "default": false, "info": "Use full frequency tail remainder."},
    "exact_static_ch": {"type": "INTEGER", "default": -1, "info": "-1=auto, 0=partial sum, 1=exact."},
    "full_ch_conv_log": {"type": "INTEGER", "default": 0, "info": "0=log real parts only, 1=log all band parts."},
    "qgrid": {"type": "INTEGER_ARRAY", "default": null, "info": "Regular q-grid for Hartree-Fock (3 integers)."},
    "bare_exchange_fraction": {"type": "REAL", "default": 1.0, "info": "Fraction of bare exchange (1.0=LDA/GGA, 0.0=HF, 0.75=PBE0)."},
    "short_range_frac_fock": {"type": "REAL", "default": 1.0, "info": "Alpha for range-separated hybrid."},
    "long_range_frac_fock": {"type": "REAL", "default": 1.0, "info": "Beta for range-separated hybrid."},
    "screening_length": {"type": "REAL", "default": 0.0, "info": "Gamma (range-separation) parameter."},
    "screening_semiconductor": {"type": "LOGICAL", "default": true, "info": "Use semiconductor screening (default)."},
    "screening_graphene": {"type": "LOGICAL", "default": false, "info": "Use graphene/zero-gap screening."},
    "screening_metal": {"type": "LOGICAL", "default": false, "info": "Use metal screening."},
    "number_partial_occup": {"type": "INTEGER", "default": 0, "info": "Number of partially occupied bands for screening."},
    "use_xdat": {"type": "LOGICAL", "default": false, "info": "Use precalculated bare exchange from x.dat."},
    "dont_use_vxcdat": {"type": "LOGICAL", "default": false, "info": "Compute VXC from VXC file instead of vxc.dat."},
    "dont_use_vxc2dat": {"type": "LOGICAL", "default": false, "info": "Do not use vxc2.dat for hybrid calculations."},
    "use_kihdat": {"type": "LOGICAL", "default": false, "info": "Use KIH matrix elements from kih.dat."},
    "cvfit": {"type": "REAL_ARRAY", "default": null, "info": "Scissors operator: evs ev0 evdel ecs ec0 ecdel (6 values, eV)."},
    "evs": {"type": "REAL", "default": 0.0, "info": "Valence band scissors shift (eV)."},
    "ev0": {"type": "REAL", "default": 0.0, "info": "Reference valence band energy (eV)."},
    "evdel": {"type": "REAL", "default": 0.0, "info": "Valence band scissors slope."},
    "ecs": {"type": "REAL", "default": 0.0, "info": "Conduction band scissors shift (eV)."},
    "ec0": {"type": "REAL", "default": 0.0, "info": "Reference conduction band energy (eV)."},
    "ecdel": {"type": "REAL", "default": 0.0, "info": "Conduction band scissors slope."},
    "cvfit_outer": {"type": "REAL_ARRAY", "default": null, "info": "Outer scissors: evs ev0 evdel ecs ec0 ecdel (eV)."},
    "evs_outer": {"type": "REAL", "default": 0.0, "info": "Outer valence scissors shift (eV)."},
    "ev0_outer": {"type": "REAL", "default": 0.0, "info": "Outer valence reference energy (eV)."},
    "evdel_outer": {"type": "REAL", "default": 0.0, "info": "Outer valence scissors slope."},
    "ecs_outer": {"type": "REAL", "default": 0.0, "info": "Outer conduction scissors shift (eV)."},
    "ec0_outer": {"type": "REAL", "default": 0.0, "info": "Outer conduction reference energy (eV)."},
    "ecdel_outer": {"type": "REAL", "default": 0.0, "info": "Outer conduction scissors slope."},
    "spline_scissors": {"type": "LOGICAL", "default": false, "info": "Use spline QP corrections from spline_scissors.dat."},
    "spline_scissors_outer": {"type": "LOGICAL", "default": false, "info": "Use spline QP corrections from spline_scissors_outer.dat."},
    "eqp_corrections": {"type": "LOGICAL", "default": false, "info": "Use QP corrections from eqp.dat."},
    "eqp_outer_corrections": {"type": "LOGICAL", "default": false, "info": "Use QP corrections from eqp_outer.dat."},
    "avgpot": {"type": "REAL", "default": 0.0, "info": "Average potential on cell faces (eV) for WFN_inner."},
    "avgpot_outer": {"type": "REAL", "default": 0.0, "info": "Average potential on cell faces (eV) for WFN_outer."},
    "skip_averagew": {"type": "LOGICAL", "default": false, "info": "Skip averaging W over minibz (debug only)."},
    "fermi_level": {"type": "REAL", "default": 0.0, "info": "Fermi level (eV)."},
    "fermi_level_relative": {"type": "LOGICAL", "default": true, "info": "Fermi level relative to DFT Fermi (default)."},
    "fermi_level_absolute": {"type": "LOGICAL", "default": false, "info": "Fermi level as absolute energy."},
    "occ_broadening": {"type": "REAL", "default": 0.1, "info": "Methfessel-Paxton smearing width (eV). Requires fermi_level_absolute."},
    "dont_symmetrize": {"type": "LOGICAL", "default": false, "info": "Skip averaging of degenerate subspace."},
    "no_symmetries_q_grid": {"type": "LOGICAL", "default": false, "info": "Sum over full BZ q-points (no symmetry reduction)."},
    "use_symmetries_q_grid": {"type": "LOGICAL", "default": true, "info": "Use symmetry reduction for q-points (default)."},
    "no_symmetries_offdiagonals": {"type": "LOGICAL", "default": false, "info": "Compute off-diagonal elements regardless of symmetry."},
    "tol_degeneracy": {"type": "REAL", "default": 1e-6, "info": "Threshold (Ry) for considering bands degenerate."},
    "degeneracy_check_override": {"type": "LOGICAL", "default": false, "info": "Suppress degeneracy check."},
    "subsample": {"type": "LOGICAL", "default": false, "info": "Use subsampling with weights from subweights.dat."},
    "fullbz_replace": {"type": "LOGICAL", "default": false, "info": "Replace unfolded BZ with full BZ (experimental)."},
    "fullbz_write": {"type": "LOGICAL", "default": false, "info": "Write BZ to files (experimental)."},
    "die_outside_sphere": {"type": "LOGICAL", "default": true, "info": "Die if G-vectors fall outside sphere after rotation."},
    "ignore_outside_sphere": {"type": "LOGICAL", "default": false, "info": "Ignore G-vectors outside sphere after rotation."},
    "use_wfn_hdf5": {"type": "LOGICAL", "default": false, "info": "Read WFN_inner in HDF5 format."},
    "dont_use_hdf5": {"type": "LOGICAL", "default": false, "info": "Disable HDF5 I/O."},
    "dont_check_norms": {"type": "LOGICAL", "default": false, "info": "Skip WFN norm checks."},
    "do_sigma_subspace": {"type": "LOGICAL", "default": false, "info": "Activate full-frequency static subspace approximation."},
    "sub_collective_redistr": {"type": "LOGICAL", "default": false, "info": "Use collective MPI for subspace redistribution."},
    "number_sigma_pools": {"type": "INTEGER", "default": null, "info": "Number of pools for parallel sigma."},
    "comm_nonblocking_cyclic": {"type": "LOGICAL", "default": false, "info": "Use non-blocking cyclic communication."},
    "accel_mtxel_band_block_size": {"type": "INTEGER", "default": 20, "info": "Inner block size for mtxel GPU kernel."},
    "accel_gpp_band_block_size": {"type": "INTEGER", "default": 16, "info": "Stride for inner loop over bands in sigma_gpp GPU kernel."},
    "accel_gpp_ig_block_size": {"type": "INTEGER", "default": 512, "info": "Stride for inner loop over G-vectors in sigma_gpp GPU kernel."},
    "mtxel_algo": {"type": "STRING", "default": null, "info": "GPU mtxel algorithm: CPU_ALGO, OPENACC_ALGO, OMP_TARGET_ALGO."},
    "sigma_gpp_algo": {"type": "STRING", "default": null, "info": "GPU sigma_gpp algorithm: CPU_ALGO, OPENACC_ALGO, OMP_TARGET_ALGO."},
    "spherical_truncation": {"type": "LOGICAL", "default": false, "info": "Spherical Coulomb truncation."},
    "cell_wire_truncation": {"type": "LOGICAL", "default": false, "info": "Wire Coulomb truncation (1D)."},
    "cell_box_truncation": {"type": "LOGICAL", "default": false, "info": "Box Coulomb truncation (0D)."},
    "cell_slab_truncation": {"type": "LOGICAL", "default": false, "info": "Slab Coulomb truncation (2D)."},
    "coulomb_truncation_radius": {"type": "REAL", "default": 0.0, "info": "Radius for spherical truncation (Bohr)."},
    "coulomb_truncation_x": {"type": "REAL", "default": 0.0, "info": "Parameter for box/wire/slab truncation."},
    "write_vcoul": {"type": "LOGICAL", "default": false, "info": "Write bare Coulomb potential to file."},
    "verbosity": {"type": "INTEGER", "default": 1, "info": "Verbosity level."},
    "set_tolerant": {"type": "LOGICAL", "default": false, "info": "Allow inconsistent input data (hidden flag)."},
    "number_kpoints": {"type": "INTEGER", "default": null, "info": "DEPRECATED: auto-detected from kpoints block."},
    "number_qpoints": {"type": "INTEGER", "default": null, "info": "DEPRECATED: auto-detected from qpoints block."}
  },
  "blocks": ["kpoints", "qpoints", "diag", "offdiag"],
  "aliases": {}
}
